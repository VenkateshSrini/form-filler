# Database configuration
# Set DB_TYPE=montydb for local development (default)
# Set DB_TYPE=mongodb for production MongoDB
DB_TYPE=montydb

# MontyDB: path to local storage directory (used when DB_TYPE=montydb)
DB_PATH=./data/formfiller_db

# MongoDB: connection URI (used only when DB_TYPE=mongodb)
# DB_URI=mongodb://localhost:27017

# Database name
DB_NAME=formfiller_db

# ---------------------------------------------------------------------------
# LLM enrichment (optional — omit LLM_PROVIDER to run in heuristic-only mode)
# ---------------------------------------------------------------------------

# Choose one provider: openai | azure_openai | anthropic | aws_bedrock
# LLM_PROVIDER=openai

# --- OpenAI (direct) -------------------------------------------------------
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_BASE_URL=                        # optional: override to any OpenAI-compatible endpoint

# --- Azure OpenAI -----------------------------------------------------------
# LLM_PROVIDER=azure_openai
# LLM_API_KEY=<azure-key>
# LLM_MODEL=<deployment-name>
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-01  # optional, default: 2024-02-01

# --- Anthropic (direct) -----------------------------------------------------
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_MODEL=claude-3-5-haiku-20241022

# --- AWS Bedrock (Anthropic Claude via Bedrock) -----------------------------
# Authentication uses the standard AWS credential chain (IAM role, instance
# profile, ECS task role, ~/.aws/credentials).  Explicit keys are optional.
# LLM_PROVIDER=aws_bedrock
# LLM_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=                   # optional: omit to use IAM role
# AWS_SECRET_ACCESS_KEY=               # optional: omit to use IAM role
# AWS_SESSION_TOKEN=                   # optional: only needed for STS sessions
